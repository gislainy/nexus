{
  "name": "knowledge-engine",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "echo \"(lint placeholder — eslint not configured yet)\" && exit 0",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate",
    "prisma:generate": "prisma generate",
    "index-paper": "tsx --env-file=.env scripts/index-paper.ts",
    "extract-pdf": "tsx --env-file=.env scripts/extract-pdf.ts",
    "batch-index": "tsx --env-file=.env scripts/batch-index.ts",
    "create-snapshot": "tsx --env-file=.env scripts/create-snapshot.ts",
    "load-ground-truth": "tsx --env-file=.env scripts/load-ground-truth.ts",
    "run-benchmark": "tsx --env-file=.env scripts/run-benchmark.ts"
  },
  "prisma": {
    "schema": "prisma/schema.prisma"
  },
  "dependencies": {
    "@prisma/client": "^6.1.0",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "js-tiktoken": "^1.0.21",
    "pdf-parse": "^2.4.5",
    "wink-bm25-text-search": "^3.1.2",
    "wink-nlp-utils": "^2.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/pdf-parse": "^1.1.5",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
