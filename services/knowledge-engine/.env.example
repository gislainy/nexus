DATABASE_URL=postgresql://nexus:nexus_dev@localhost:55432/nexus_dev?schema=knowledge_engine
PORT=8004
EMBEDDING_DIM=768
CHUNK_SIZE=512
CHUNK_OVERLAP=64
EMBEDDING_MODEL=nomic-embed-text
OLLAMA_BASE_URL=http://localhost:11434
RETRIEVAL_STRATEGY=hybrid
RRF_K=60
# Semantic gate applied inside DenseRetrievalService (minimum cosine similarity).
# Also acts as default post-fusion threshold for the `dense` strategy.
DENSE_MIN_COSINE=0.5
# Optional post-fusion threshold override. When set, applies the same value to all
# strategies (back-compat with previous single-threshold behavior).
# Defaults when unset: dense=DENSE_MIN_COSINE, sparse=0, hybrid=0.
# RELEVANCE_THRESHOLD=

# LLM generation (Ollama)
# For daily development, llama3.2 is faster and lighter.
# For the qualification presentation, switch to phi4 (14B, MIT license, 3.7% hallucination rate).
LLM_MODEL=llama3.2
LLM_MAX_TOKENS=1024
# Ollama context window (num_ctx). Increase if /answer is truncating with large topK.
LLM_NUM_CTX=8192
# Optional: override the base URL used only by the generation service.
# Defaults to OLLAMA_BASE_URL. Set this when the LLM runs on a different host
# (e.g. a GPU box) than the embedding model, or to fault-inject generation
# failures in tests without breaking retrieval.
# LLM_BASE_URL=http://localhost:11434

# Python Bridge — cross-encoder reranker (optional)
# Leave empty or unset to disable reranking (pipeline works without it).
# Set to http://localhost:8009 when the python-bridge service is running.
RERANKER_URL=
RERANKER_TOP_K=5
