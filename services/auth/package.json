{
  "name": "auth",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "pnpm test:unit && pnpm test:integration",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "lint": "echo \"(lint placeholder)\" && exit 0",
    "db:migrate": "prisma migrate deploy",
    "db:generate": "prisma generate"
  },
  "prisma": {
    "schema": "../../shared/types/prisma/schema.prisma"
  },
  "dependencies": {
    "@nexus/types": "workspace:*",
    "@prisma/client": "^6.1.0",
    "bcryptjs": "^2.4.3",
    "fastify": "^5.2.0",
    "fastify-plugin": "^5.1.0",
    "jsonwebtoken": "^9.0.2",
    "uuid": "^11.0.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^25.9.1",
    "@types/uuid": "^10.0.0",
    "prisma": "^6.1.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
