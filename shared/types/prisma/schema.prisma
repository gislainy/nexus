// Prisma schema for the Nexus shared database. Every service connects to the
// same DATABASE_URL and consumes the generated client from @prisma/client.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================================
// Domain configuration (produced by C0, consumed at runtime)
// ============================================================

model DomainConfig {
  id            String   @id @default(uuid())
  domainName    String
  domainVersion String
  description   String
  tagSet        String[]
  active        Boolean  @default(false)
  createdAt     DateTime @default(now())
  approvedBy    String
  approvedAt    DateTime

  dimensions        DimensionDefinition[]
  profiles          ProfileDefinition[]
  warrants          WarrantDefinition[]
  vetos             VetoDefinition[]
  conflicts         ConflictDefinition[]
  artifactVariables ArtifactVariable[]
  questionTemplates QuestionTemplate[]
  projects          Project[]

  @@unique([domainName, domainVersion])
}

model DimensionDefinition {
  id             String       @id
  domainConfigId String
  name           String
  description    String
  tag            String

  domainConfig DomainConfig        @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)
  warrants     WarrantDefinition[]

  @@unique([domainConfigId, id])
}

model ProfileDefinition {
  id             String          @id
  domainConfigId String
  name           String
  description    String
  vocabulary     String[]
  technicalDepth TechnicalDepth

  domainConfig DomainConfig @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)

  @@unique([domainConfigId, id])
}

model WarrantDefinition {
  id                String   @id
  domainConfigId    String
  dimensionId       String
  structuralWarrant String
  sources           String[]

  domainConfig DomainConfig         @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)
  dimension    DimensionDefinition  @relation(fields: [dimensionId], references: [id], onDelete: Cascade)
}

model VetoDefinition {
  id              String   @id
  domainConfigId  String
  condition       String
  description     String
  evaluationRule  Json
  remediationPath String[]
  sources         String[]

  domainConfig DomainConfig @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)
}

model ConflictDefinition {
  id             String @id @default(uuid())
  domainConfigId String
  dimensionAId   String
  dimensionBId   String
  conditionA     Json
  conditionB     Json
  description    String

  domainConfig DomainConfig @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)
}

model ArtifactVariable {
  id               String @id
  domainConfigId   String
  name             String
  description      String
  extractionHint   String
  mapsToQuestionId String

  domainConfig DomainConfig @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)
}

// ============================================================
// Project & collaboration
// ============================================================

model Project {
  id             String        @id @default(uuid())
  name           String
  description    String
  domainConfigId String
  status         ProjectStatus @default(ACTIVE)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  domainConfig    DomainConfig    @relation(fields: [domainConfigId], references: [id])
  collaborators   Collaborator[]
  sessions        Session[]
  gitConnections  GitConnection[]
  artifacts       Artifact[]
}

model Collaborator {
  id        String   @id @default(uuid())
  projectId String
  name      String
  email     String
  profileId String
  joinedAt  DateTime @default(now())

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  profile Profile @relation(fields: [profileId], references: [id])
  answers Answer[]
}

model Profile {
  id                   String                       @id @default(uuid())
  type                 ProfileType
  confidence           Float
  identificationMethod ProfileIdentificationMethod
  createdAt            DateTime                     @default(now())
  updatedAt            DateTime                     @updatedAt

  collaborators Collaborator[]
}

model Session {
  id             String        @id @default(uuid())
  projectId      String
  status         SessionStatus @default(IN_PROGRESS)
  xstateSnapshot Json?
  startedAt      DateTime      @default(now())
  completedAt    DateTime?

  project           Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questionInstances QuestionInstance[]
  answers           Answer[]
  recommendation    Recommendation?
}

// ============================================================
// Question catalog & runtime instances
// ============================================================

model QuestionTemplate {
  id                    String            @id
  domainConfigId        String
  dimension             String
  targetProfiles        ProfileType[]
  textPt                String
  textEn                String
  textByProfile         Json
  inputType             QuestionInputType
  options               String[]
  isCriticalForArgument Boolean           @default(true)
  isEntryNode           Boolean           @default(false)

  domainConfig    DomainConfig          @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)
  outgoingEdges   QuestionTemplateEdge[] @relation("EdgeSource")
  incomingEdges   QuestionTemplateEdge[] @relation("EdgeTarget")
  extractions     ArtifactExtraction[]
}

model QuestionTemplateEdge {
  id               String        @id @default(uuid())
  sourceTemplateId String
  targetTemplateId String
  dimension        String
  guard            Json?
  profileTypes     ProfileType[]

  source QuestionTemplate @relation("EdgeSource", fields: [sourceTemplateId], references: [id], onDelete: Cascade)
  target QuestionTemplate @relation("EdgeTarget", fields: [targetTemplateId], references: [id], onDelete: Cascade)
}

model QuestionInstance {
  id               String                 @id @default(uuid())
  sessionId        String
  templateId       String?
  parentInstanceId String?
  generatedByLLM   Boolean                @default(false)
  llmPromptUsed    String?
  textShown        String
  dimension        String
  inputType        QuestionInputType
  options          String[]
  status           QuestionInstanceStatus @default(PENDING)
  order            Int
  createdAt        DateTime               @default(now())
  skippedAt        DateTime?

  session Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer  Answer?
}

model Answer {
  id                   String           @id @default(uuid())
  sessionId            String
  questionInstanceId   String           @unique
  collaboratorId       String
  value                String
  confidence           AnswerConfidence
  delegatedTo          String?
  epistemicConfidence  Float
  answeredAt           DateTime         @default(now())
  source               AnswerSource
  artifactExtractionId String?
  generatedByLLM       Boolean          @default(false)

  session            Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionInstance   QuestionInstance    @relation(fields: [questionInstanceId], references: [id], onDelete: Cascade)
  collaborator       Collaborator        @relation(fields: [collaboratorId], references: [id])
  artifactExtraction ArtifactExtraction? @relation(fields: [artifactExtractionId], references: [id])
  argumentsAsGround  Argument[]          @relation("ArgumentGrounds")
}

// ============================================================
// Artifacts & extraction
// ============================================================

model GitConnection {
  id          String              @id @default(uuid())
  projectId   String
  gitRepoUrl  String
  branch      String
  commitSha   String
  status      GitConnectionStatus @default(CONNECTED)
  connectedAt DateTime            @default(now())
  lastSyncAt  DateTime?

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifacts Artifact[]
}

model Artifact {
  id                String                 @id @default(uuid())
  projectId         String
  gitConnectionId   String?
  type              ArtifactType
  origin            ArtifactOrigin
  filename          String
  filePath          String?
  storageKey        String
  storageBucket     String
  storageSizeBytes  Int
  mimeType          String
  analysisStatus    ArtifactAnalysisStatus @default(PENDING)
  createdAt         DateTime               @default(now())
  analyzedAt        DateTime?

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  gitConnection GitConnection?       @relation(fields: [gitConnectionId], references: [id])
  extractions   ArtifactExtraction[]
}

model ArtifactExtraction {
  id                 String   @id @default(uuid())
  artifactId         String
  questionTemplateId String
  extractedValue     String
  confidence         Float
  evidenceSnippet    String
  extractedAt        DateTime @default(now())

  artifact         Artifact         @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  questionTemplate QuestionTemplate @relation(fields: [questionTemplateId], references: [id])
  answers          Answer[]
}

// ============================================================
// Argumentation
// ============================================================

model Recommendation {
  id                    String                  @id @default(uuid())
  sessionId             String                  @unique
  verdict               RecommendationVerdict
  argumentAcceptability Json
  orientationText       String
  blockerDiagnosis      String?
  vetosTriggered        String[]
  generatedAt           DateTime                @default(now())

  session   Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  arguments Argument[]
}

model Argument {
  id                String                       @id @default(uuid())
  recommendationId  String
  dimension         String
  warrant           String
  backingChunkIds   String[]
  claim             String
  acceptability     ArgumentAcceptabilityStatus
  defeatedBy        String?
  suspendedByVeto   String?

  recommendation Recommendation @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  defeater       Argument?      @relation("ArgumentDefeats", fields: [defeatedBy], references: [id])
  defeated       Argument[]     @relation("ArgumentDefeats")
  grounds        Answer[]       @relation("ArgumentGrounds")
}

// ============================================================
// Benchmark
// ============================================================

model LLMBenchmarkRecord {
  id              String   @id @default(uuid())
  experimentId    String?
  provider        String
  component       String
  task            String
  prompt          String
  response        String
  latencyMs       Int
  tokensIn        Int
  tokensOut       Int
  evaluationScore Float?
  timestamp       DateTime @default(now())

  experiment BenchmarkExperiment? @relation(fields: [experimentId], references: [id])
}

model BenchmarkExperiment {
  id                 String           @id @default(uuid())
  name               String
  description        String
  component          String
  task               String
  candidateModels    String[]
  testPrompts        Json
  evaluationCriteria Json
  status             ExperimentStatus @default(PLANNED)
  winnerModel        String?
  decisionRationale  String?
  createdAt          DateTime         @default(now())
  completedAt        DateTime?

  runs    BenchmarkRun[]
  records LLMBenchmarkRecord[]
}

model BenchmarkRun {
  id               String           @id @default(uuid())
  experimentId     String
  promptId         String
  provider         String
  response         String
  latencyMs        Int
  tokensIn         Int
  tokensOut        Int
  evaluationScore  Float
  evaluationMethod EvaluationMethod
  evaluationNotes  String?
  ranAt            DateTime         @default(now())

  experiment BenchmarkExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)
}

// ============================================================
// Enums
// ============================================================

enum TechnicalDepth {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ProfileType {
  MANAGER
  ARCHITECT
  DEVELOPER
  CLINICAL
  REGULATORY
}

enum ProfileIdentificationMethod {
  DECLARATIVE
  OWNER_REVISION
}

enum SessionStatus {
  IN_PROGRESS
  SUFFICIENT
  AWAITING_DELEGATION
  READY_FOR_ARGUMENTATION
  COMPLETED
}

enum QuestionInputType {
  BOOLEAN
  SELECT
  MULTI_SELECT
  TEXT
  SCALE
}

enum QuestionInstanceStatus {
  PENDING
  ANSWERED
  SKIPPED
}

enum AnswerConfidence {
  CERTAIN
  UNCERTAIN
  DELEGATED
}

enum AnswerSource {
  MANUAL
  ARTIFACT
}

enum GitConnectionStatus {
  CONNECTED
  SYNCING
  FAILED
}

enum ArtifactType {
  CODE
  DOCUMENTATION
  ARCHITECTURE_DIAGRAM
  FHIR_RESOURCE
  HL7_MESSAGE
  OPENEHR_ARCHETYPE
  DICOM_CONFIG
  OTHER
}

enum ArtifactOrigin {
  GIT
  UPLOAD
}

enum ArtifactAnalysisStatus {
  PENDING
  ANALYZED
  FAILED
}

enum RecommendationVerdict {
  NOT_RECOMMENDED
  PARTIALLY_RECOMMENDED
  STRONGLY_RECOMMENDED
}

enum ArgumentAcceptabilityStatus {
  ACCEPTED
  DEFEATED
  SUSPENDED
}

enum ExperimentStatus {
  PLANNED
  RUNNING
  EVALUATING
  COMPLETED
}

enum EvaluationMethod {
  MANUAL
  AUTOMATED
  LLM_AS_JUDGE
}
