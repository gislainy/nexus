// Prisma schema for the Nexus shared database. Every service connects to the
// same DATABASE_URL and consumes the generated client from @prisma/client.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ============================================================
// Domain configuration (produced by C0, consumed at runtime)
// ============================================================

model DomainConfig {
  id            String   @id @default(uuid())
  domainName    String   @map("domain_name")
  domainVersion String   @map("domain_version")
  description   String
  technology    String
  tagSet        String[] @map("tag_set")
  active        Boolean  @default(false)
  createdAt     DateTime @default(now()) @map("created_at")
  approvedBy    String   @map("approved_by")
  approvedAt    DateTime @map("approved_at")

  dimensions        DimensionDefinition[]
  profiles          ProfileDefinition[]
  warrants          WarrantDefinition[]
  vetos             VetoDefinition[]
  conflicts         ConflictDefinition[]
  artifactVariables ArtifactVariable[]
  questionTemplates QuestionTemplate[]
  projects          Project[]

  @@unique([domainName, domainVersion])
  @@map("domain_config")
}

model DimensionDefinition {
  id             String @id
  domainConfigId String @map("domain_config_id")
  name           String
  description    String
  tag            String

  domainConfig DomainConfig        @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)
  warrants     WarrantDefinition[]

  @@unique([domainConfigId, id])
  @@map("dimension_definition")
}

model ProfileDefinition {
  id             String         @id
  domainConfigId String         @map("domain_config_id")
  name           String
  description    String
  vocabulary     String[]
  technicalDepth TechnicalDepth @map("technical_depth")

  domainConfig DomainConfig @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)

  @@unique([domainConfigId, id])
  @@map("profile_definition")
}

model WarrantDefinition {
  id                String   @id
  domainConfigId    String   @map("domain_config_id")
  dimensionId       String   @map("dimension_id")
  structuralWarrant String   @map("structural_warrant")
  sources           String[]

  domainConfig DomainConfig        @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)
  dimension    DimensionDefinition @relation(fields: [dimensionId], references: [id], onDelete: Cascade)

  @@map("warrant_definition")
}

model VetoDefinition {
  id              String   @id
  domainConfigId  String   @map("domain_config_id")
  condition       String
  description     String
  evaluationRule  Json     @map("evaluation_rule")
  remediationPath String[] @map("remediation_path")
  sources         String[]

  domainConfig DomainConfig @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)

  @@map("veto_definition")
}

model ConflictDefinition {
  id             String @id @default(uuid())
  domainConfigId String @map("domain_config_id")
  dimensionAId   String @map("dimension_a_id")
  dimensionBId   String @map("dimension_b_id")
  conditionA     Json   @map("condition_a")
  conditionB     Json   @map("condition_b")
  description    String

  domainConfig DomainConfig @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)

  @@map("conflict_definition")
}

model ArtifactVariable {
  id               String @id
  domainConfigId   String @map("domain_config_id")
  name             String
  description      String
  extractionHint   String @map("extraction_hint")
  mapsToQuestionId String @map("maps_to_question_id")

  domainConfig DomainConfig @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)

  @@map("artifact_variable")
}

// ============================================================
// Identity & authentication (managed by services/auth/)
// ============================================================

model User {
  id           String         @id @default(uuid())
  email        String         @unique
  passwordHash String         @map("password_hash")
  name         String
  createdAt    DateTime       @default(now()) @map("created_at")
  updatedAt    DateTime       @updatedAt @map("updated_at")
  refreshTokens RefreshToken[]
  collaborators Collaborator[]
  invitesSent   CollaboratorInvite[]

  @@map("user")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_token")
}

// ============================================================
// Project & collaboration
// ============================================================

model Project {
  id             String        @id @default(uuid())
  name           String
  description    String
  domainConfigId String        @map("domain_config_id")
  status         ProjectStatus @default(ACTIVE)
  createdAt      DateTime      @default(now()) @map("created_at")
  updatedAt      DateTime      @updatedAt @map("updated_at")

  domainConfig   DomainConfig         @relation(fields: [domainConfigId], references: [id])
  collaborators  Collaborator[]
  invites        CollaboratorInvite[]
  sessions       Session[]
  gitConnections GitConnection[]
  artifacts      Artifact[]

  @@map("project")
}

model Collaborator {
  id        String   @id @default(uuid())
  projectId String   @map("project_id")
  userId    String?  @map("user_id")
  name      String
  email     String
  profileId String   @map("profile_id")
  joinedAt  DateTime @default(now()) @map("joined_at")

  project Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user    User?    @relation(fields: [userId], references: [id])
  profile Profile  @relation(fields: [profileId], references: [id])
  answers Answer[]

  @@map("collaborator")
}

model CollaboratorInvite {
  id               String    @id @default(uuid())
  projectId        String    @map("project_id")
  invitedBy        String    @map("invited_by")
  inviteeEmail     String    @map("invitee_email")
  suggestedProfile String    @map("suggested_profile")
  token            String    @unique
  status           String    @default("PENDING")
  expiresAt        DateTime  @map("expires_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  acceptedAt       DateTime? @map("accepted_at")

  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  inviter User    @relation(fields: [invitedBy], references: [id])

  @@map("collaborator_invite")
}

model Profile {
  id                   String                      @id @default(uuid())
  type                 ProfileType
  confidence           Float
  identificationMethod ProfileIdentificationMethod @map("identification_method")
  createdAt            DateTime                    @default(now()) @map("created_at")
  updatedAt            DateTime                    @updatedAt @map("updated_at")

  collaborators Collaborator[]

  @@map("profile")
}

model Session {
  id             String        @id @default(uuid())
  projectId      String        @map("project_id")
  status         SessionStatus @default(IN_PROGRESS)
  xstateSnapshot Json?         @map("xstate_snapshot")
  startedAt      DateTime      @default(now()) @map("started_at")
  completedAt    DateTime?     @map("completed_at")

  project           Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  questionInstances QuestionInstance[]
  answers           Answer[]
  recommendation    Recommendation?

  @@map("session")
}

// ============================================================
// Question catalog & runtime instances
// ============================================================

model QuestionTemplate {
  id                    String            @id
  domainConfigId        String            @map("domain_config_id")
  dimension             String
  targetProfiles        ProfileType[]     @map("target_profiles")
  textPt                String            @map("text_pt")
  textEn                String            @map("text_en")
  textByProfile         Json              @map("text_by_profile")
  inputType             QuestionInputType @map("input_type")
  options               String[]
  isCriticalForArgument Boolean           @default(true) @map("is_critical_for_argument")
  isEntryNode           Boolean           @default(false) @map("is_entry_node")

  domainConfig  DomainConfig           @relation(fields: [domainConfigId], references: [id], onDelete: Cascade)
  outgoingEdges QuestionTemplateEdge[] @relation("EdgeSource")
  incomingEdges QuestionTemplateEdge[] @relation("EdgeTarget")
  extractions   ArtifactExtraction[]

  @@map("question_template")
}

model QuestionTemplateEdge {
  id               String        @id @default(uuid())
  sourceTemplateId String        @map("source_template_id")
  targetTemplateId String        @map("target_template_id")
  dimension        String
  guard            Json?
  profileTypes     ProfileType[] @map("profile_types")

  source QuestionTemplate @relation("EdgeSource", fields: [sourceTemplateId], references: [id], onDelete: Cascade)
  target QuestionTemplate @relation("EdgeTarget", fields: [targetTemplateId], references: [id], onDelete: Cascade)

  @@map("question_template_edge")
}

model QuestionInstance {
  id               String                 @id @default(uuid())
  sessionId        String                 @map("session_id")
  templateId       String?                @map("template_id")
  parentInstanceId String?                @map("parent_instance_id")
  generatedByLLM   Boolean                @default(false) @map("generated_by_llm")
  llmPromptUsed    String?                @map("llm_prompt_used")
  textShown        String                 @map("text_shown")
  dimension        String
  inputType        QuestionInputType      @map("input_type")
  options          String[]
  status           QuestionInstanceStatus @default(PENDING)
  order            Int
  createdAt        DateTime               @default(now()) @map("created_at")
  skippedAt        DateTime?              @map("skipped_at")

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  answer  Answer?

  @@map("question_instance")
}

model Answer {
  id                   String           @id @default(uuid())
  sessionId            String           @map("session_id")
  questionInstanceId   String           @unique @map("question_instance_id")
  collaboratorId       String           @map("collaborator_id")
  value                String
  confidence           AnswerConfidence
  delegatedTo          String?          @map("delegated_to")
  epistemicConfidence  Float            @map("epistemic_confidence")
  answeredAt           DateTime         @default(now()) @map("answered_at")
  source               AnswerSource
  artifactExtractionId String?          @map("artifact_extraction_id")
  generatedByLLM       Boolean          @default(false) @map("generated_by_llm")

  session            Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  questionInstance   QuestionInstance    @relation(fields: [questionInstanceId], references: [id], onDelete: Cascade)
  collaborator       Collaborator        @relation(fields: [collaboratorId], references: [id])
  artifactExtraction ArtifactExtraction? @relation(fields: [artifactExtractionId], references: [id])
  argumentsAsGround  ArgumentGround[]

  @@map("answer")
}

// ============================================================
// Artifacts & extraction
// ============================================================

model GitConnection {
  id          String              @id @default(uuid())
  projectId   String              @map("project_id")
  gitRepoUrl  String              @map("git_repo_url")
  branch      String
  commitSha   String              @map("commit_sha")
  status      GitConnectionStatus @default(CONNECTED)
  connectedAt DateTime            @default(now()) @map("connected_at")
  lastSyncAt  DateTime?           @map("last_sync_at")

  project   Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  artifacts Artifact[]

  @@map("git_connection")
}

model Artifact {
  id               String                 @id @default(uuid())
  projectId        String                 @map("project_id")
  gitConnectionId  String?                @map("git_connection_id")
  type             ArtifactType
  origin           ArtifactOrigin
  filename         String
  filePath         String?                @map("file_path")
  storageKey       String                 @map("storage_key")
  storageBucket    String                 @map("storage_bucket")
  storageSizeBytes Int                    @map("storage_size_bytes")
  mimeType         String                 @map("mime_type")
  analysisStatus   ArtifactAnalysisStatus @default(PENDING) @map("analysis_status")
  createdAt        DateTime               @default(now()) @map("created_at")
  analyzedAt       DateTime?              @map("analyzed_at")

  project       Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  gitConnection GitConnection?       @relation(fields: [gitConnectionId], references: [id])
  extractions   ArtifactExtraction[]

  @@map("artifact")
}

model ArtifactExtraction {
  id                 String   @id @default(uuid())
  artifactId         String   @map("artifact_id")
  questionTemplateId String   @map("question_template_id")
  extractedValue     String   @map("extracted_value")
  confidence         Float
  evidenceSnippet    String   @map("evidence_snippet")
  extractedAt        DateTime @default(now()) @map("extracted_at")

  artifact         Artifact         @relation(fields: [artifactId], references: [id], onDelete: Cascade)
  questionTemplate QuestionTemplate @relation(fields: [questionTemplateId], references: [id])
  answers          Answer[]

  @@map("artifact_extraction")
}

// ============================================================
// Argumentation
// ============================================================

model Recommendation {
  id                    String                @id @default(uuid())
  sessionId             String                @unique @map("session_id")
  verdict               RecommendationVerdict
  argumentAcceptability Json                  @map("argument_acceptability")
  orientationText       String                @map("orientation_text")
  blockerDiagnosis      String?               @map("blocker_diagnosis")
  vetosTriggered        String[]              @map("vetos_triggered")
  generatedAt           DateTime              @default(now()) @map("generated_at")

  session   Session    @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  arguments Argument[]

  @@map("recommendation")
}

model Argument {
  id               String                      @id @default(uuid())
  recommendationId String                      @map("recommendation_id")
  dimension        String
  warrant          String
  backingChunkIds  String[]                    @map("backing_chunk_ids")
  claim            String
  acceptability    ArgumentAcceptabilityStatus
  defeatedBy       String?                     @map("defeated_by")
  suspendedByVeto  String?                     @map("suspended_by_veto")

  recommendation Recommendation   @relation(fields: [recommendationId], references: [id], onDelete: Cascade)
  defeater       Argument?        @relation("ArgumentDefeats", fields: [defeatedBy], references: [id])
  defeated       Argument[]       @relation("ArgumentDefeats")
  grounds        ArgumentGround[]

  @@map("argument")
}

model ArgumentGround {
  answerId   String @map("answer_id")
  argumentId String @map("argument_id")

  answer   Answer   @relation(fields: [answerId], references: [id], onDelete: Cascade)
  argument Argument @relation(fields: [argumentId], references: [id], onDelete: Cascade)

  @@id([answerId, argumentId])
  @@index([argumentId])
  @@map("argument_ground")
}

// ============================================================
// Benchmark
// ============================================================

model LLMBenchmarkRecord {
  id              String   @id @default(uuid())
  experimentId    String?  @map("experiment_id")
  provider        String
  component       String
  task            String
  prompt          String
  response        String
  latencyMs       Int      @map("latency_ms")
  tokensIn        Int      @map("tokens_in")
  tokensOut       Int      @map("tokens_out")
  evaluationScore Float?   @map("evaluation_score")
  timestamp       DateTime @default(now())

  experiment BenchmarkExperiment? @relation(fields: [experimentId], references: [id])

  @@map("llm_benchmark_record")
}

model BenchmarkExperiment {
  id                 String           @id @default(uuid())
  name               String
  description        String
  component          String
  task               String
  candidateModels    String[]         @map("candidate_models")
  testPrompts        Json             @map("test_prompts")
  evaluationCriteria Json             @map("evaluation_criteria")
  status             ExperimentStatus @default(PLANNED)
  winnerModel        String?          @map("winner_model")
  decisionRationale  String?          @map("decision_rationale")
  createdAt          DateTime         @default(now()) @map("created_at")
  completedAt        DateTime?        @map("completed_at")

  runs    BenchmarkRun[]
  records LLMBenchmarkRecord[]

  @@map("benchmark_experiment")
}

model BenchmarkRun {
  id               String           @id @default(uuid())
  experimentId     String           @map("experiment_id")
  promptId         String           @map("prompt_id")
  provider         String
  response         String
  latencyMs        Int              @map("latency_ms")
  tokensIn         Int              @map("tokens_in")
  tokensOut        Int              @map("tokens_out")
  evaluationScore  Float            @map("evaluation_score")
  evaluationMethod EvaluationMethod @map("evaluation_method")
  evaluationNotes  String?          @map("evaluation_notes")
  ranAt            DateTime         @default(now()) @map("ran_at")

  experiment BenchmarkExperiment @relation(fields: [experimentId], references: [id], onDelete: Cascade)

  @@map("benchmark_run")
}

// ============================================================
// Enums
// ============================================================

enum TechnicalDepth {
  LOW
  MEDIUM
  HIGH
}

enum ProjectStatus {
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum ProfileType {
  MANAGER
  ARCHITECT
  DEVELOPER
  CLINICAL
  REGULATORY
}

enum ProfileIdentificationMethod {
  DECLARATIVE
  OWNER_REVISION
}

enum SessionStatus {
  IN_PROGRESS
  SUFFICIENT
  AWAITING_DELEGATION
  READY_FOR_ARGUMENTATION
  COMPLETED
}

enum QuestionInputType {
  BOOLEAN
  SELECT
  MULTI_SELECT
  TEXT
  SCALE
}

enum QuestionInstanceStatus {
  PENDING
  ANSWERED
  SKIPPED
}

enum AnswerConfidence {
  CERTAIN
  UNCERTAIN
  DELEGATED
}

enum AnswerSource {
  MANUAL
  ARTIFACT
}

enum GitConnectionStatus {
  CONNECTED
  SYNCING
  FAILED
}

enum ArtifactType {
  CODE
  DOCUMENTATION
  ARCHITECTURE_DIAGRAM
  FHIR_RESOURCE
  HL7_MESSAGE
  OPENEHR_ARCHETYPE
  DICOM_CONFIG
  OTHER
}

enum ArtifactOrigin {
  GIT
  UPLOAD
}

enum ArtifactAnalysisStatus {
  PENDING
  ANALYZED
  FAILED
}

enum RecommendationVerdict {
  NOT_RECOMMENDED
  PARTIALLY_RECOMMENDED
  STRONGLY_RECOMMENDED
}

enum ArgumentAcceptabilityStatus {
  ACCEPTED
  DEFEATED
  SUSPENDED
}

enum ExperimentStatus {
  PLANNED
  RUNNING
  EVALUATING
  COMPLETED
}

enum EvaluationMethod {
  MANUAL
  AUTOMATED
  LLM_AS_JUDGE
}
